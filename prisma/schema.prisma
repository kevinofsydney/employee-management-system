generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  ADMIN
  TRANSLATOR
}

enum AccountStatus {
  INVITED
  ONBOARDING_IN_PROGRESS
  SUBMITTED_FOR_REVIEW
  ACTIVE
  INACTIVE
  ARCHIVED
  EXPIRED
}

enum InviteStatus {
  PENDING
  REDEEMED
  EXPIRED
  CANCELLED
}

enum OnboardingStep {
  PROFILE
  DOCUMENTS
  AGREEMENTS
  CONFIRMATION
}

enum DocumentType {
  EMPLOYEE_CONTRACT
  SERVICES_CONFIDENTIALITY_AGREEMENT
  TFN_DECLARATION
  SUPERANNUATION_DETAILS
  SUPER_FUND_CONSENT
}

enum DocumentStatus {
  PENDING
  UPLOADED
  ACCEPTED
  RESUBMISSION_REQUESTED
  QUARANTINED
}

enum AuditAction {
  INVITE_SENT
  INVITE_REDEEMED
  ONBOARDING_STEP_SAVED
  ONBOARDING_SUBMITTED
  REMINDER_EMAIL_SENT
  USER_ACTIVATED
  USER_DEACTIVATED
  DOCUMENT_UPLOADED
  DOCUMENT_ACCEPTED
  DOCUMENT_VIEWED
  DOCUMENT_DOWNLOADED
  DOCUMENT_RESUBMISSION_REQUESTED
  TIMESHEET_CREATED
  TIMESHEET_SUBMITTED
  TIMESHEET_APPROVED
  TIMESHEET_REJECTED
  TIMESHEET_REOPENED
  ENTRY_SPLIT
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  CSV_EXPORTED
  JOB_RUN_COMPLETED
}

enum TimesheetEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RateType {
  STANDARD
  SUNDAY
  OVERTIME
  PUBLIC_HOLIDAY
}

model User {
  id                 String                 @id @default(cuid())
  clerkUserId        String                 @unique
  email              String                 @unique
  fullName           String?
  preferredName      String?
  role               AppRole
  status             AccountStatus          @default(INVITED)
  phone              String?
  mailingAddress     String?
  city               String?
  tfn                String?
  bsb                String?
  yearsOfExperience  Int?
  certifications     String?
  privacyAcceptedAt  DateTime?
  isAdminMfaVerified Boolean                @default(false)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  languagePairs      UserLanguagePair[]
  onboarding         OnboardingSubmission?
  documents          Document[]
  invitesSent        Invite[]               @relation("InvitedBy")
  invites            Invite[]               @relation("InvitedUser")
  timesheetEntries   TimesheetEntry[]
  notifications      Notification[]
  auditLogs          AuditLog[]             @relation("ActorAuditLogs")
}

model Invite {
  id            String       @id @default(cuid())
  email         String
  tokenHash     String       @unique
  status        InviteStatus @default(PENDING)
  expiresAt     DateTime
  redeemedAt    DateTime?
  sentAt        DateTime     @default(now())
  invitedById   String
  invitedUserId String?
  invitedBy     User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  invitedUser   User?        @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model OnboardingSubmission {
  id                    String         @id @default(cuid())
  userId                String         @unique
  currentStep           OnboardingStep @default(PROFILE)
  profileCompletedAt    DateTime?
  documentsCompletedAt  DateTime?
  agreementsCompletedAt DateTime?
  submittedAt           DateTime?
  signatureName         String?
  signatureIp           String?
  signatureTimestamp    DateTime?
  docEmailFallback      Boolean        @default(false)
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id            String         @id @default(cuid())
  userId        String
  type          DocumentType
  status        DocumentStatus @default(PENDING)
  fileName      String?
  mimeType      String?
  sizeBytes     Int?
  driveFileId   String?
  driveFolderId String?
  driveViewLink String?
  adminComment  String?
  uploadedAt    DateTime?
  acceptedAt    DateTime?
  requestedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessAudits  DocumentAccessAudit[]

  @@unique([userId, type])
}

model DocumentAccessAudit {
  id         String      @id @default(cuid())
  documentId String
  actorId    String
  action     AuditAction
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Project {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LanguagePair {
  id        String             @id @default(cuid())
  label     String             @unique
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  users     UserLanguagePair[]
}

model UserLanguagePair {
  userId         String
  languagePairId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  languagePair   LanguagePair @relation(fields: [languagePairId], references: [id], onDelete: Cascade)

  @@id([userId, languagePairId])
}

model Event {
  id        String           @id @default(cuid())
  name      String
  startDate DateTime         @db.Date
  endDate   DateTime         @db.Date
  city      String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  entries   TimesheetEntry[]
}

model TimesheetEntry {
  id           String               @id @default(cuid())
  userId       String
  eventId      String
  date         DateTime             @db.Date
  startTime    String               // HH:mm format, rounded to 15min
  endTime      String               // HH:mm format, rounded to 15min
  hours        Decimal              @db.Decimal(6, 2)
  rateType     RateType             @default(STANDARD)
  comment      String?
  status       TimesheetEntryStatus @default(PENDING)
  adminComment String?
  submittedAt  DateTime             @default(now())
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  event        Event                @relation(fields: [eventId], references: [id], onDelete: Restrict)

  @@index([userId, eventId, date, status])
}

model HourlyRate {
  id        String   @id @default(cuid())
  rateType  RateType @unique
  amount    Decimal  @db.Decimal(8, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  targetUserId String?
  action       AuditAction
  entityType   String
  entityId     String
  detailsJson  String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
}
